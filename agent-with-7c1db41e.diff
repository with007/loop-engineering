+def _collect_agents(pr):
+    """从 tasks.md 收集所有涉及的 agent 名。确保当前 agent 也在列表中。"""
+    tp = os.path.join(pr, "tasks.md")
+    agents = set()
+    if os.path.exists(tp):
+        with open(tp, "r", encoding="utf-8") as f:
+            for line in f:
+                if re.match(r'^- \[.\]', line):
+                    m_assignee = re.search(r'\(→\s*(\w+)\)', line)
+                    if m_assignee:
+                        agents.add(m_assignee.group(1))
+    # 确保当前 agent 也在列表中（即使尚未出现在 tasks.md 中）
+    current = _agent_name(pr)
+    if current:
+        agents.add(current)
+    return sorted(agents)
+
